{
  "format": "corro/v1",
  "gameType": "journey",
  "engineVersion": "^1.0",
  "id": "great-route",
  "name": {
    "es": "La Gran Ruta",
    "en": "The Great Route"
  },
  "author": "kastwey",
  "version": "0.1.0",
  "locales": [
    "en",
    "es"
  ],
  "players": {
    "min": 2,
    "max": 6
  },
  "journeyRules": {
    "goalKm": 1000,
    "targetScore": 5000,
    "handSize": 6,
    "stackHazards": false,
    "limitCap": 50,
    "initialHazard": "stop"
  },
  "ruleGroups": [
    {
      "id": "journey",
      "nameKey": "rules.group.journey"
    }
  ],
  "houseRules": [
    {
      "id": "journeyTargetScore",
      "group": "journey",
      "type": "number",
      "default": 5000,
      "min": 0,
      "max": 20000,
      "step": 500,
      "editableByHost": true,
      "nameKey": "rules.journeyTargetScore"
    },
    {
      "id": "journeyGoalKm",
      "group": "journey",
      "type": "number",
      "default": 1000,
      "min": 100,
      "max": 2000,
      "step": 100,
      "editableByHost": true,
      "nameKey": "rules.journeyGoalKm"
    },
    {
      "id": "journeyStackHazards",
      "group": "journey",
      "type": "toggle",
      "default": false,
      "editableByHost": true,
      "nameKey": "rules.journeyStackHazards"
    },
    {
      "id": "journeyAllImmunitiesBonus",
      "group": "journey",
      "type": "number",
      "default": 300,
      "min": 0,
      "max": 1000,
      "step": 100,
      "editableByHost": true,
      "nameKey": "rules.journeyAllImmunitiesBonus"
    }
  ],
  "tokens": [
    {
      "id": "car",
      "nameKey": "tokens.car"
    },
    {
      "id": "van",
      "nameKey": "tokens.van"
    },
    {
      "id": "motorbike",
      "nameKey": "tokens.motorbike"
    },
    {
      "id": "bus",
      "nameKey": "tokens.bus"
    },
    {
      "id": "lorry",
      "nameKey": "tokens.lorry"
    },
    {
      "id": "taxi",
      "nameKey": "tokens.taxi"
    }
  ]
}
