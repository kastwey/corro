{
  "format": "corro/v1",
  "gameType": "journey",
  "engineVersion": "^1.0",
  "id": "la-gran-ruta",
  "name": {
    "es": "La Gran Ruta",
    "en": "The Great Route"
  },
  "author": "kastwey",
  "version": "0.1.0",
  "locales": ["es", "en"],
  "players": {
    "min": 2,
    "max": 6
  },
  "journeyRules": {
    "goalKm": 1000,
    "targetScore": 5000,
    "handSize": 6,
    "stackHazards": false,
    "limitCap": 50,
    "initialHazard": "stop"
  },
  "ruleGroups": [
    { "id": "journey", "nameKey": "rules.group.journey" }
  ],
  "houseRules": [
    {
      "id": "journeyTargetScore",
      "group": "journey",
      "type": "number",
      "default": 5000,
      "min": 0,
      "max": 20000,
      "step": 500,
      "editableByHost": true,
      "nameKey": "rules.journeyTargetScore"
    },
    {
      "id": "journeyGoalKm",
      "group": "journey",
      "type": "number",
      "default": 1000,
      "min": 100,
      "max": 2000,
      "step": 100,
      "editableByHost": true,
      "nameKey": "rules.journeyGoalKm"
    },
    {
      "id": "journeyStackHazards",
      "group": "journey",
      "type": "toggle",
      "default": false,
      "editableByHost": true,
      "nameKey": "rules.journeyStackHazards"
    },
    {
      "id": "journeyAllImmunitiesBonus",
      "group": "journey",
      "type": "number",
      "default": 300,
      "min": 0,
      "max": 1000,
      "step": 100,
      "editableByHost": true,
      "nameKey": "rules.journeyAllImmunitiesBonus"
    }
  ],
  "tokens": [
    { "id": "coche", "nameKey": "tokens.coche" },
    { "id": "furgoneta", "nameKey": "tokens.furgoneta" },
    { "id": "moto", "nameKey": "tokens.moto" },
    { "id": "autobus", "nameKey": "tokens.autobus" },
    { "id": "camion", "nameKey": "tokens.camion" },
    { "id": "taxi", "nameKey": "tokens.taxi" }
  ]
}
