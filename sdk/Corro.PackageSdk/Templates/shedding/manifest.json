{
  "format": "corro/v1",
  "gameType": "shedding",
  "engineVersion": "^1.0",
  "id": "starter-shedding",
  "name": { "en": "Starter Shedding Game", "es": "Juego inicial de descarte" },
  "author": "Your name",
  "version": "0.1.0",
  "locales": ["en", "es"],
  "players": { "min": 2, "max": 2 },
  "sheddingRules": {
