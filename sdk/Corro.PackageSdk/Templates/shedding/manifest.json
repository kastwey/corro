    "allowDoubles": false,
    "stacking": "none",
    "lastCardCall": false,
    "lastCardPenalty": 2
  },
  "tokens": [
    { "id": "circle", "nameKey": "tokens.circle" },
    { "id": "diamond", "nameKey": "tokens.diamond" }
  ]
}
