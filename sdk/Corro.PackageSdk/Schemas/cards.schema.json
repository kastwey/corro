{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kastwey/corro/main/sdk/Corro.PackageSdk/Schemas/cards.schema.json",
  "title": "Corro card catalog",
  "$comment": "Optional visual art is a sibling file at assets/cards/<card-id>.svg (64x64 path geometry), not a JSON property.",
  "oneOf": [
    { "$ref": "#/$defs/propertyDeck" },
    { "$ref": "#/$defs/journeyDeck" },
    { "$ref": "#/$defs/assemblyDeck" },
    { "$ref": "#/$defs/draftDeck" },
    { "$ref": "#/$defs/sheddingDeck" },
    { "$ref": "#/$defs/explodingDeck" }
  ],
  "$defs": {
    "cardId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Stable card id. To override Corro's neutral drawing, add a sibling file at assets/cards/<this-id>.svg using viewBox='0 0 64 64' and path geometry only. Do not add an svg property to cards.json."
    },
    "artColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "description": "Optional package-owned #RRGGBB accent used for this card's frame and SVG silhouette. Keep semantic names/help authoritative; never rely on colour alone."
    },
    "propertyDeck": { "type": "array", "items": { "$ref": "#/$defs/propertyCard" } },
    "journeyDeck": { "type": "array", "items": { "$ref": "#/$defs/journeyCard" } },
    "assemblyDeck": { "type": "array", "items": { "$ref": "#/$defs/assemblyCard" } },
    "draftDeck": { "type": "array", "items": { "$ref": "#/$defs/draftCard" } },
    "sheddingDeck": { "type": "array", "items": { "$ref": "#/$defs/sheddingCard" } },
    "explodingDeck": { "type": "array", "items": { "$ref": "#/$defs/explodingCard" } },
    "propertyCard": {
      "title": "Property card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "deck", "textKey", "effect"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "deck": { "type": "string" },
        "textKey": { "type": "string" },
        "effect": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["moveTo", "moveBy", "money", "collectFromEach", "payEach", "payPerBuilding", "sendToHolding", "grantReleasePass"] },
            "target": { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
            "collectPass": { "type": "boolean" },
            "steps": { "type": "integer" },
            "amount": { "type": "integer" },
            "perSmallBuilding": { "type": "integer" },
            "perBigBuilding": { "type": "integer" },
            "rentMultiplier": { "type": "integer", "minimum": 1 },
            "utilityTimesDice": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "journeyCard": {
      "title": "Journey card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "type", "count", "nameKey"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "type": { "enum": ["distance", "attack", "remedy", "immunity"] },
        "value": { "type": "integer", "minimum": 0 },
        "kind": { "type": "string" },
        "hazardClass": { "enum": ["stopper", "limiter"] },
        "shieldsKinds": { "type": "array", "items": { "type": "string" } },
        "count": { "type": "integer", "minimum": 1 },
        "maxPlaysPerHand": { "type": "integer", "minimum": 1 },
        "premium": { "type": "boolean" },
        "nameKey": { "type": "string" },
        "playedKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "assemblyCard": {
      "title": "Assembly card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "type", "count", "nameKey"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "type": { "enum": ["piece", "attack", "remedy", "special"] },
        "color": { "type": "string" },
        "specialKind": { "enum": ["swapPiece", "stealPiece", "plague", "scrapHands", "fullSwap"] },
        "count": { "type": "integer", "minimum": 1 },
        "nameKey": { "type": "string" },
        "playedKey": { "type": "string" }
      },
      "additionalProperties": false
    },
    "draftCard": {
      "title": "Draft card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "type", "count", "nameKey"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "type": { "enum": ["points", "multiplier", "set", "scale", "majority", "dessert", "extra"] },
        "count": { "type": "integer", "minimum": 1 },
        "nameKey": { "type": "string" },
        "value": { "type": "integer" },
        "factor": { "type": "integer" },
        "setSize": { "type": "integer" },
        "setPoints": { "type": "integer" },
        "scale": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "icons": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "sheddingCard": {
      "title": "Shedding card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "type", "count", "nameKey"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "type": { "enum": ["number", "skip", "reverse", "drawTwo", "wild", "wildDrawFour"] },
        "color": { "type": ["string", "null"] },
        "value": { "type": "integer", "minimum": 0 },
        "count": { "type": "integer", "minimum": 1 },
        "nameKey": { "type": "string" },
        "points": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "explodingCard": {
      "title": "Exploding card (optional art: assets/cards/<id>.svg)",
      "type": "object",
      "required": ["id", "type", "count", "nameKey"],
      "properties": {
        "id": { "$ref": "#/$defs/cardId" },
        "artColor": { "$ref": "#/$defs/artColor" },
        "type": { "enum": ["bomb", "defuse", "skip", "attack", "seeFuture", "shuffle", "favor", "nope", "cat"] },
        "count": { "type": "integer", "minimum": 1 },
        "nameKey": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
